# Rename this file to .env before running the server

# Get a free connection string from MongoDB Atlas (atlas.mongodb.com)
# or use local Mongo: mongodb://127.0.0.1:27017/expense-tracker
MONGODB_URI=mongodb://127.0.0.1:27017/expense-tracker

# Any long random string — used to sign login tokens
JWT_SECRET=myCollegeProject2026Secret

# Port the backend server runs on
PORT=5000
